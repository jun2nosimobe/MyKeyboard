                <TextView android:id="@+id/btn_shift" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1.5" android:text="⇧" android:gravity="center" android:clickable="true" android:background="#66E0E0E0" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_z" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="z" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_x" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="x" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_c" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="c" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_v" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="v" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_b" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="b" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_n" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="n" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_m" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="m" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
