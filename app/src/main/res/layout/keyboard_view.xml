                <TextView android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="1" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="2" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="3" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="4" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="5" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="6" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="7" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="8" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="9" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_0" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="0" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
