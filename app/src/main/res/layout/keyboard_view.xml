                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:id="@+id/btn_a" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="a" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_s" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="s" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_d" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="d" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_f" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="f" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_g" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="g" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_h" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="h" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
