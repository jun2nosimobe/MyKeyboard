                <TextView android:id="@+id/btn_y" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="y" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_u" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="u" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_i" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="i" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_o" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="o" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_p" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="p" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
