                <TextView android:id="@+id/btn_w" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="w" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_e" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="e" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
                <TextView android:id="@+id/btn_r" android:layout_width="0dp" android:layout_height="45dp" android:layout_weight="1" android:text="r" android:gravity="center" android:clickable="true" android:background="?android:attr/selectableItemBackground" android:textSize="18sp" android:textColor="#000000" />
